@page "/game/{GameUId}"
@page "/game/{GameUId}/{PlayerUId}"
@implements IDisposable
@using Microsoft.AspNetCore.WebUtilities
@using TicTacToe.Logic
@using TicTacToe.Models
@using TicTacToe.Helpers

<div class="game__wrapper">

    @if (_gameManager?.IsNotFound == true)
    {
        <ExpiredContainer OnBackHome='() => _navigationManager.NavigateTo("")' />
    }
    else if (_gameManager?.GameStage == null)
    {
        <LoadingContainer />
    }
    else if (_gameManager?.GameStage == EnumGameStage.Preparing)
    {
        <PreparingContainer Options="@_gameManager?.GamePreparation" />
    }
    else if (_gameManager?.GameStage == EnumGameStage.Starting)
    {
        <StartingContainer OnCountdownEnd="StartMatch" />
    }
    else if (_gameManager?.GameStage == EnumGameStage.Started)
    {
        <GameContainer GameManager="@_gameManager" />
    }

</div>

@code {
    private readonly NavigationManager _navigationManager;
    private readonly PersistentComponentState _applicationState;
    private readonly IGameStateService _gameStateService;
    private PersistingComponentStateSubscription _subscription;
    private GameManager _gameManager;

    public Game(NavigationManager navigationManager, PersistentComponentState applicationState, IGameStateService gameStateService)
    {
        _navigationManager = navigationManager;
        _applicationState = applicationState;
        _gameStateService = gameStateService;
    }

    [Parameter]
    public string GameUId { get; set; }
    [Parameter]
    public string PlayerUId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        GameUId = IdGenerator.Normalize(GameUId);
        PlayerUId = IdGenerator.Normalize(PlayerUId);

        _subscription = _applicationState.RegisterOnPersisting(PersistState);

        var hubUrl = _navigationManager.ToAbsoluteUri(GameHub.HubUrl).ToString();
        _gameManager = new GameManager(hubUrl, GameUId);
        _gameManager.PropertyChanged += async (o, e) => await InvokeAsync(StateHasChanged);

        if (!_applicationState.TryTakeFromJson<GameState>(GameManager.PersistenceKey, out var state))
            state = _gameStateService.GetState(GameUId);

        if (state is not null)
            _gameManager.Initialize(state, PlayerUId);

        await _gameManager.StartConnection();
    }

    private Task PersistState()
    {
        if (_gameManager?.State is not null)
            _applicationState.PersistAsJson(GameManager.PersistenceKey, _gameManager.State);

        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await InitGame();
        await _gameManager.JoinGame();
        await _gameManager.SynchronizeState();
    }

    private async Task InitGame()
    {
        var queryString = new Uri(_navigationManager.Uri).Query;
        var query = QueryHelpers.ParseQuery(queryString);

        if (!query.TryGetValue("init", out var pt))
            return;

        var playerType = Enum.Parse(typeof(EnumPlayerType), pt.ToString().ToUpper()) as EnumPlayerType?;
        if (!playerType.HasValue)
            return;

        _gameManager.Player ??= new Player(PlayerUId);
        _gameManager.Player.PlayerType = playerType.Value;

        await _gameManager.CreateGame();

        // Clean up the URL to prevent accidental re-creation on refresh
        var uri = _navigationManager.ToAbsoluteUri(_navigationManager.Uri).GetLeftPart(UriPartial.Path);
        _navigationManager.NavigateTo(uri, replace: true);
    }

    private async Task StartMatch() => await _gameManager.StartMatch();

    public void Dispose() => _subscription.Dispose();
}

<div class="preparing-container__wrapper">

    <div class=@cssCopiedInfo>
        Link copied
    </div>

    <header class="preparing-container__header">
        Waiting for second player...
    </header>

    @if (!string.IsNullOrEmpty(Options.OpponentId))
    {
        <section class="preparing-container__section">
            <label class="preparing-container__label">
                Invite <span class="preparing-container__label--player">Player @Options.OpponentName</span>
            </label>
            <div class="preparing-container__link">
                <span class="preparing-container__link-text">@LinkForOponent</span>
                <div class="preparing-container__buttons">
                    <button type="button" class="preparing-container__copy-button" @onclick="()=>CopyTextToClipboard(LinkForOponent)">Copy</button>
                    <button type="button" class="preparing-container__copy-button preparing-container__copy-button--qr" @onclick='()=>ShowQrCode(LinkForOponent, $"Join as Player {Options.OpponentName}")'>QR</button>
                </div>
            </div>
        </section>
    }

    <section class="preparing-container__section preparing-container__section--spectator">
        <label class="preparing-container__label">
            Invite spectators
        </label>
        <div class="preparing-container__link">
            <span class="preparing-container__link-text">@LinkForSpectator</span>
            <div class="preparing-container__buttons">
                <button type="button" class="preparing-container__copy-button" @onclick="()=>CopyTextToClipboard(LinkForSpectator)">Copy</button>
                <button type="button" class="preparing-container__copy-button preparing-container__copy-button--qr" @onclick='()=>ShowQrCode(LinkForSpectator, "Join as Spectator")'>QR</button>
            </div>
        </div>
    </section>

    @if (showQrOverlay)
    {
        <QRCodeOverlay Url="@qrUrl" Title="@qrTitle" OnClose="HideQrCode" />
    }

</div>

@code {
    private NavigationManager NavigationManager;
    private IJSRuntime JSRuntime;

    public PreparingContainer(NavigationManager navigationManager, IJSRuntime jsRuntime)
    {
        NavigationManager = navigationManager;
        JSRuntime = jsRuntime;
    }

    [Parameter]
    public GamePreparation Options { get; set; }

    private string LinkForSpectator => NavigationManager.ToAbsoluteUri(GameLogic.GetSpectatorUrl(Options.GameId)).ToString();
    private string LinkForOponent => NavigationManager.ToAbsoluteUri(GameLogic.GetJoinUrl(Options.GameId, Options.OpponentId)).ToString();

    private bool visibleCopiedInfo;
    private string cssCopiedInfo => visibleCopiedInfo ? "preparing-container__copied preparing-container__copied--visible" : "preparing-container__copied";

    private bool showQrOverlay;
    private string qrUrl = string.Empty;
    private string qrTitle = string.Empty;

    private async Task CopyTextToClipboard(string text)
    {
        var result = await JSRuntime.InvokeAsync<bool>("clipboardCopy.copyText", text);
        if (result)
            ShowCopiedInfo();
    }

    private void ShowQrCode(string url, string title)
    {
        qrUrl = url;
        qrTitle = title;
        showQrOverlay = true;
    }

    private void HideQrCode()
    {
        showQrOverlay = false;
    }

    private void ShowCopiedInfo()
    {
        visibleCopiedInfo = true;

        var timer = new System.Timers.Timer()
        {
            Interval = 2000,
            AutoReset = false,
            Enabled = true,
        };
        timer.Elapsed += OnTimedEvent;
    }

    private void HideCopiedInfo()
    {
        visibleCopiedInfo = false;
        InvokeAsync(StateHasChanged);
    }

    private void OnTimedEvent(Object source, System.Timers.ElapsedEventArgs e)
    {
        HideCopiedInfo();
    }

}
